using FigCommissionAnalyticsEngine.Application.UseCases.Agents.GetAllAgents;
using Microsoft.EntityFrameworkCore;

namespace FigCommissionAnalyticsEngine.Infrastructure.Data.Queries;

public class GetAllAgentsReader : IGetAllAgentsReader
{
    private readonly AppDbContext _context;

    public GetAllAgentsReader(AppDbContext context)
    {
        _context = context;
    }

    public async Task<GetAllAgentsResponse> GetInsuranceCarrierBreakdownAsync(
        GetAllAgentsRequest request,
        CancellationToken cancellationToken)
    {
        var agents = await _context.Agents
            .AsNoTracking()
            .OrderBy(a => a.AgentName)
            .ToListAsync(cancellationToken);

        var response = new GetAllAgentsResponse
        {
            Agents = agents.Select(a => new Application.UseCases.Agents.GetAllAgents.Agent
            {
                AgentId = a.AgentId,
                AgentName = a.AgentName
            }).ToList()
        };

        return response;
    }
}
