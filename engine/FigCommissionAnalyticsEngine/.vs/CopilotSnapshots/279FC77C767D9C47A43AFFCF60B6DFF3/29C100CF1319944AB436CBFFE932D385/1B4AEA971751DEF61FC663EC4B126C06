using FigCommissionAnalyticsEngine.Application.UseCases.InsuranceCarrierBreakdown.GetInsuranceCarrierBreakdown;
using Microsoft.EntityFrameworkCore;

namespace FigCommissionAnalyticsEngine.Infrastructure.Data.Queries;

public class InsuranceCarrierBreakdownReader : IInsuranceCarrierBreakdownReader
{
    private readonly AppDbContext _context;

    public InsuranceCarrierBreakdownReader(AppDbContext context)
    {
        _context = context;
    }

    public async Task<GetInsuranceCarrierBreakdownResponse> GetInsuranceCarrierBreakdownAsync(
        GetInsuranceCarrierBreakdownRequest request, 
        CancellationToken cancellationToken)
    {

        var agent = request.AgentId.HasValue ? await _context.Agents
            .AsNoTracking()
            .FirstOrDefaultAsync(a => a.AgentId == request.AgentId.Value, cancellationToken) : null;

        var statements = await _context.AgentCarrierCommissionStatements
            .Include(s => s.AgentCarrier)
                .ThenInclude(ac => ac.Carrier)
            .Where(s => !request.AgentId.HasValue || s.AgentCarrier.AgentId == request.AgentId.Value)
            .AsNoTracking()
            .ToListAsync(cancellationToken);

        var filteredStatements = statements
            .Where(s => !string.IsNullOrEmpty(s.StatementDate) &&
                        DateOnly.TryParse(s.StatementDate, out var date) &&
                        (!request.StartDate.HasValue || date >= request.StartDate.Value) &&
                        (!request.EndDate.HasValue || date <= request.EndDate.Value.AddMonths(1).AddDays(-request.EndDate.Value.Day + 1)))
            .ToList();

        var maxEndDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-DateTime.Today.Day));

        var tempMinStartDate1 = statements
            .Select(s => DateOnly.Parse(s.StatementDate))
            .DefaultIfEmpty(DateOnly.MinValue)
            .Min();

        var tempMinStartDate2 = maxEndDate.AddMonths(-11);
        var tempStartDateDays = tempMinStartDate2.Day;
        tempMinStartDate2 = tempMinStartDate2.AddDays(-tempStartDateDays + 1);

        var minStartDate = tempMinStartDate1 > tempMinStartDate2 ? tempMinStartDate1 : tempMinStartDate2;

        var totalCommission = filteredStatements.Sum(s => s.CommissionAmount ?? 0);

        var carrierBreakdowns = filteredStatements
            .GroupBy(s => new { s.AgentCarrier.CarrierId, s.AgentCarrier.Carrier.CarrierName })
            .Select(g =>
            {
                var carrierTotal = g.Sum(s => s.CommissionAmount ?? 0);

                return new AgentCarrierBreakdown
                {
                    CarrierId = g.Key.CarrierId,
                    CarrierName = g.Key.CarrierName,
                    AgentCarrierTotalCommission = carrierTotal,
                    AgentCarrierRelativeWeight = totalCommission > 0 ? (double)carrierTotal / totalCommission : 0
                };
            })
            .OrderByDescending(c => c.AgentCarrierTotalCommission)
            .ToList();

        var carriers = await _context.Carriers
            .AsNoTracking()
            .ToListAsync(cancellationToken);

        carrierBreakdowns = carriers.FindAll(c => !carrierBreakdowns.Any(cb => cb.CarrierId == c.CarrierId))
            .Select(c => new AgentCarrierBreakdown
            {
                CarrierId = c.CarrierId,
                CarrierName = c.CarrierName,
                AgentCarrierTotalCommission = 0,
                AgentCarrierRelativeWeight = 0
            })
            .Concat(carrierBreakdowns)
            .OrderByDescending(c => c.AgentCarrierTotalCommission)
            .ToList();

        return new GetInsuranceCarrierBreakdownResponse
        {
            AgentId = request?.AgentId,
            AgentName = agent?.AgentName ?? "Average Advisor",
            MinStartDate = minStartDate,
            MaxEndDate = maxEndDate,
            AgentCarrierBreakdowns = carrierBreakdowns
        };
    }
}
